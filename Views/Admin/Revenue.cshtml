@{
    ViewData["Title"] = "Revenue Report";
    Layout = "_Layout";
    var totalRevenue = ViewBag.TotalRevenue as decimal? ?? 0;
    var monthlyStats = ViewBag.MonthlyStats as IEnumerable<Hotel_Booking_System.Models.ViewModels.MonthlyStatsViewModel> ?? new List<Hotel_Booking_System.Models.ViewModels.MonthlyStatsViewModel>();
}

<style>
    .admin-wrapper {
        max-width: 1200px;
        margin: 40px auto;
        padding: 0 20px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 12px;
    }

        .page-header h2 {
            font-size: 26px;
            font-weight: 700;
        }

    .revenue-summary {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .revenue-card {
        background: white;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        text-align: center;
    }

        .revenue-card .label {
            font-size: 13px;
            color: #6b7280;
            margin-bottom: 4px;
        }

        .revenue-card .value {
            font-size: 28px;
            font-weight: 700;
            color: #0f172a;
        }

        .revenue-card .sub {
            font-size: 12px;
            color: #9ca3af;
            margin-top: 4px;
        }

    .admin-table-section {
        background: white;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        overflow-x: auto;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        min-width: 500px;
    }

    th {
        text-align: left;
        font-size: 12px;
        color: #6b7280;
        font-weight: 600;
        text-transform: uppercase;
        padding: 12px;
        border-bottom: 2px solid #f0f0f0;
    }

    td {
        padding: 12px;
        font-size: 14px;
        border-bottom: 1px solid #f3f4f6;
    }

    .btn-sm {
        padding: 4px 12px;
        border-radius: 6px;
        border: 1px solid #e5e7eb;
        background: white;
        font-size: 12px;
        cursor: pointer;
        text-decoration: none;
        color: #4b5563;
        display: inline-block;
    }

        .btn-sm:hover {
            border-color: #2563eb;
            color: #2563eb;
        }
</style>

<div class="admin-wrapper">
    <div class="page-header">
        <h2>Revenue Report</h2>
        <a href="@Url.Action("Dashboard", "Admin")" class="btn-sm" style="padding: 8px 16px;">
            <i class="fa-regular fa-arrow-left"></i> Back
        </a>
    </div>

    <div class="revenue-summary">
        <div class="revenue-card">
            <div class="label">Total Revenue</div>
            <div class="value">$@totalRevenue.ToString("N0")</div>
            <div class="sub">All time</div>
        </div>
        <div class="revenue-card">
            <div class="label">Monthly Average</div>
            <div class="value">$@(monthlyStats.Any() ? (monthlyStats.Average(m => m.Revenue)).ToString("N0") : "0")</div>
            <div class="sub">Last 12 months</div>
        </div>
        <div class="revenue-card">
            <div class="label">Total Bookings</div>
            <div class="value">@monthlyStats.Sum(m => m.Bookings).ToString("N0")</div>
            <div class="sub">Last 12 months</div>
        </div>
    </div>

    <div class="admin-table-section">
        <h3 style="margin-bottom: 16px;">Monthly Breakdown</h3>
        @if (monthlyStats.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th>Month</th>
                        <th>Bookings</th>
                        <th>Revenue</th>
                        <th>Unique Guests</th>
                        <th>Occupancy</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in monthlyStats)
                    {
                        <tr>
                            <td><strong>@m.Month @m.Year</strong></td>
                            <td>@m.Bookings</td>
                            <td>$@m.Revenue.ToString("N0")</td>
                            <td>@m.UniqueGuests</td>
                            <td>@m.OccupancyRate.ToString("F0")%</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p style="text-align: center; color: #9ca3af; padding: 20px;">No revenue data available</p>
        }
    </div>
</div>
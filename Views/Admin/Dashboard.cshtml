@model Hotel_Booking_System.Models.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_Layout";
}

<style>
    .admin-wrapper {
        max-width: 1200px;
        margin: 40px auto;
        padding: 0 20px;
    }

    .admin-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 12px;
    }

        .admin-header h2 {
            font-size: 26px;
            font-weight: 700;
        }

    .quick-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .btn-quick {
        padding: 10px 18px;
        background: white;
        border: 1.5px solid #e5e7eb;
        border-radius: 10px;
        font-weight: 600;
        font-size: 13px;
        color: #4b5563;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all 0.2s;
    }

        .btn-quick:hover {
            border-color: #2563eb;
            color: #2563eb;
            background: #f8fafc;
        }

        .btn-quick.primary {
            background: #2563eb;
            color: white;
            border-color: #2563eb;
        }

            .btn-quick.primary:hover {
                background: #1d4ed8;
                border-color: #1d4ed8;
            }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 16px;
        padding: 22px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        transition: transform 0.2s;
        text-decoration: none;
        color: inherit;
        display: block;
    }

        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.1);
        }

    .stat-icon {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        margin-bottom: 14px;
    }

        .stat-icon.blue {
            background: #eff6ff;
            color: #2563eb;
        }

        .stat-icon.green {
            background: #f0fdf4;
            color: #16a34a;
        }

        .stat-icon.amber {
            background: #fffbeb;
            color: #d97706;
        }

        .stat-icon.red {
            background: #fef2f2;
            color: #dc2626;
        }

        .stat-icon.purple {
            background: #f3e8ff;
            color: #9333ea;
        }

    .stat-value {
        font-size: 26px;
        font-weight: 700;
    }

    .stat-label {
        font-size: 13px;
        color: #6b7280;
        margin-top: 4px;
    }

    .stat-sub {
        font-size: 12px;
        color: #9ca3af;
        margin-top: 2px;
    }

    .admin-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 24px;
    }

    .admin-table-section {
        background: white;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .table-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
        flex-wrap: wrap;
        gap: 8px;
    }

        .table-header h3 {
            font-size: 17px;
            font-weight: 600;
        }

        .table-header a {
            font-size: 13px;
            color: #2563eb;
            text-decoration: none;
            font-weight: 500;
        }

            .table-header a:hover {
                text-decoration: underline;
            }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        text-align: left;
        font-size: 12px;
        color: #6b7280;
        font-weight: 600;
        text-transform: uppercase;
        padding: 10px 12px;
        border-bottom: 2px solid #f0f0f0;
    }

    td {
        padding: 12px 12px;
        font-size: 14px;
        border-bottom: 1px solid #f3f4f6;
    }

    .status-badge {
        padding: 4px 12px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 600;
    }

    .status-Confirmed {
        background: #dcfce7;
        color: #15803d;
    }

    .status-Pending {
        background: #fef9c3;
        color: #a16207;
    }

    .status-Cancelled {
        background: #fee2e2;
        color: #b91c1c;
    }

    .status-CheckedIn {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .status-CheckedOut {
        background: #f3f4f6;
        color: #4b5563;
    }

    .btn-sm {
        padding: 4px 12px;
        border-radius: 6px;
        border: 1px solid #e5e7eb;
        background: white;
        font-size: 12px;
        cursor: pointer;
        text-decoration: none;
        color: #4b5563;
        display: inline-block;
    }

        .btn-sm:hover {
            border-color: #2563eb;
            color: #2563eb;
        }

        .btn-sm.danger:hover {
            border-color: #dc2626;
            color: #dc2626;
        }

        .btn-sm.primary {
            background: #2563eb;
            color: white;
            border-color: #2563eb;
        }

            .btn-sm.primary:hover {
                background: #1d4ed8;
            }

    .quick-stats {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .quick-stat-item {
        background: white;
        border-radius: 12px;
        padding: 16px 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .quick-stat-item .label {
            font-size: 14px;
            color: #6b7280;
        }

        .quick-stat-item .value {
            font-weight: 700;
            font-size: 18px;
        }

    .empty-state {
        text-align: center;
        padding: 30px 20px;
        color: #9ca3af;
    }

        .empty-state i {
            font-size: 36px;
            margin-bottom: 8px;
            display: block;
        }

    @@media (max-width: 1024px) {
        .admin-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .admin-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<div class="admin-wrapper">
    <div class="admin-header">
        <h2>Dashboard</h2>
        <div class="quick-actions">
            <a href="@Url.Action("Create", "Properties")" class="btn-quick primary">
                <i class="fa-solid fa-plus"></i> Add Property
            </a>
            <a href="@Url.Action("Properties", "Admin")" class="btn-quick">
                <i class="fa-solid fa-building"></i> Manage Properties
            </a>
            <a href="@Url.Action("Reservations", "Admin")" class="btn-quick">
                <i class="fa-regular fa-calendar"></i> All Reservations
            </a>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="stats-grid">
        <a href="@Url.Action("Properties", "Admin")" class="stat-card">
            <div class="stat-icon blue"><i class="fa-solid fa-building"></i></div>
            <div class="stat-value">@Model?.TotalProperties.ToString("N0") ?? "0"</div>
            <div class="stat-label">Total Properties</div>
            <div class="stat-sub">@Model?.ActiveProperties.ToString("N0") ?? "0" active</div>
        </a>
        <a href="@Url.Action("Reservations", "Admin")" class="stat-card">
            <div class="stat-icon green"><i class="fa-regular fa-calendar-check"></i></div>
            <div class="stat-value">@Model?.TotalReservations.ToString("N0") ?? "0"</div>
            <div class="stat-label">Total Reservations</div>
            <div class="stat-sub">@Model?.ActiveReservations.ToString("N0") ?? "0" confirmed</div>
        </a>
        <a href="@Url.Action("Users", "Admin")" class="stat-card">
            <div class="stat-icon purple"><i class="fa-regular fa-user"></i></div>
            <div class="stat-value">@Model?.TotalUsers.ToString("N0") ?? "0"</div>
            <div class="stat-label">Total Users</div>
        </a>
        <a href="@Url.Action("Revenue", "Admin")" class="stat-card">
            <div class="stat-icon amber"><i class="fa-solid fa-dollar-sign"></i></div>
            <div class="stat-value">$@(Model?.TotalRevenue.ToString("N0") ?? "0")</div>
            <div class="stat-label">Total Revenue</div>
            <div class="stat-sub">$@(Model?.MonthlyRevenue.ToString("N0") ?? "0") this month</div>
        </a>
    </div>

    <!-- Main Grid -->
    <div class="admin-grid">
        <!-- Recent Reservations -->
        <div class="admin-table-section">
            <div class="table-header">
                <h3>Recent Reservations</h3>
                <a href="@Url.Action("Reservations", "Admin")">View All →</a>
            </div>

            @if (Model?.RecentReservations != null && Model.RecentReservations.Any())
            {
                <table>
                    <thead>
                        <tr>
                            <th>Guest</th>
                            <th>Property</th>
                            <th>Check-In</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.RecentReservations.Take(5))
                        {
                            <tr>
                                <td>@r.GuestName</td>
                                <td>@r.PropertyName</td>
                                <td>@r.CheckInDate.ToString("MMM dd")</td>
                                <td><span class="status-badge status-@r.Status">@r.Status</span></td>
                                <td>
                                    <a href="@Url.Action("AdminDetails", "Reservation", new { id = r.Id })" class="btn-sm">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <i class="fa-regular fa-calendar"></i>
                    <p>No recent reservations</p>
                </div>
            }
        </div>

        <!-- Quick Stats -->
        <div>
            <div class="quick-stats">
                <div class="quick-stat-item">
                    <span class="label">Pending Reservations</span>
                    <span class="value" style="color: #d97706;">@Model?.PendingReservations.ToString("N0") ?? "0"</span>
                </div>
                <div class="quick-stat-item">
                    <span class="label">Cancelled Reservations</span>
                    <span class="value" style="color: #dc2626;">@Model?.CancelledReservations.ToString("N0") ?? "0"</span>
                </div>
                <div class="quick-stat-item">
                    <span class="label">Featured Properties</span>
                    <span class="value" style="color: #2563eb;">@Model?.FeaturedProperties.ToString("N0") ?? "0"</span>
                </div>
                <div class="quick-stat-item">
                    <span class="label">Average Rating</span>
                    <span class="value" style="color: #f59e0b;">@(Model?.AverageRating.ToString("F1") ?? "0.0") ⭐</span>
                </div>
                <div class="quick-stat-item">
                    <span class="label">Occupancy Rate</span>
                    <span class="value" style="color: #059669;">@(Model?.OccupancyRate.ToString("F0") ?? "0")%</span>
                </div>
            </div>

            <!-- Quick Links -->
            <div style="margin-top: 16px; display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                <a href="@Url.Action("Reports", "Admin")" class="btn-quick" style="justify-content: center;">
                    <i class="fa-solid fa-chart-bar"></i> Reports
                </a>
                <a href="@Url.Action("Analytics", "Admin")" class="btn-quick" style="justify-content: center;">
                    <i class="fa-solid fa-chart-pie"></i> Analytics
                </a>
            </div>
        </div>
    </div>
</div>
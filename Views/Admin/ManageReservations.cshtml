@model IEnumerable<Hotel_Booking_System.Models.ViewModels.ReservationViewModel>

@{
    ViewData["Title"] = "Manage Reservations";
    Layout = "_Layout";
    var reservations = Model ?? new List<Hotel_Booking_System.Models.ViewModels.ReservationViewModel>();
}

<style>
    .admin-wrapper {
        max-width: 1200px;
        margin: 40px auto;
        padding: 0 20px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 12px;
    }

        .page-header h2 {
            font-size: 26px;
            font-weight: 700;
        }

    .filters-bar {
        background: white;
        border-radius: 16px;
        padding: 18px 22px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        display: grid;
        grid-template-columns: 1fr 1fr 1fr auto;
        gap: 14px;
        align-items: end;
        margin-bottom: 22px;
    }

    .form-label {
        display: block;
        font-size: 12px;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        margin-bottom: 6px;
    }

    .form-control {
        width: 100%;
        padding: 10px 14px;
        border: 1.5px solid #e5e7eb;
        border-radius: 10px;
        font-size: 14px;
    }

        .form-control:focus {
            outline: none;
            border-color: #2563eb;
        }

    .btn-filter {
        padding: 11px 18px;
        background: #1a1a1a;
        color: white;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        font-size: 13px;
        cursor: pointer;
        white-space: nowrap;
    }

        .btn-filter:hover {
            background: #374151;
        }

    .btn-primary {
        padding: 12px 24px;
        background: #2563eb;
        color: white;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: background 0.2s;
    }

        .btn-primary:hover {
            background: #1d4ed8;
            color: white;
        }

    .btn-sm {
        padding: 4px 12px;
        border-radius: 6px;
        border: 1px solid #e5e7eb;
        background: white;
        font-size: 12px;
        cursor: pointer;
        text-decoration: none;
        color: #4b5563;
        display: inline-block;
    }

        .btn-sm:hover {
            border-color: #2563eb;
            color: #2563eb;
        }

        .btn-sm.primary {
            background: #2563eb;
            color: white;
            border-color: #2563eb;
        }

            .btn-sm.primary:hover {
                background: #1d4ed8;
            }

        .btn-sm.danger {
            border-color: #dc2626;
            color: #dc2626;
        }

            .btn-sm.danger:hover {
                background: #fee2e2;
            }

    .status-badge {
        padding: 4px 12px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 600;
    }

    .status-Confirmed {
        background: #dcfce7;
        color: #15803d;
    }

    .status-Pending {
        background: #fef9c3;
        color: #a16207;
    }

    .status-Cancelled {
        background: #fee2e2;
        color: #b91c1c;
    }

    .status-CheckedIn {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .status-CheckedOut {
        background: #f3f4f6;
        color: #4b5563;
    }

    .admin-table-section {
        background: white;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        overflow-x: auto;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        min-width: 800px;
    }

    th {
        text-align: left;
        font-size: 12px;
        color: #6b7280;
        font-weight: 600;
        text-transform: uppercase;
        padding: 12px;
        border-bottom: 2px solid #f0f0f0;
    }

    td {
        padding: 12px;
        font-size: 14px;
        border-bottom: 1px solid #f3f4f6;
    }

    .action-group {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .empty-state {
        text-align: center;
        padding: 40px 20px;
        color: #9ca3af;
    }

        .empty-state i {
            font-size: 48px;
            margin-bottom: 12px;
            display: block;
        }

    .toast-success {
        padding: 12px 20px;
        border-radius: 10px;
        margin-bottom: 16px;
        background: #dcfce7;
        color: #15803d;
        border: 1px solid #bbf7d0;
        font-weight: 500;
        font-size: 14px;
    }

    .toast-error {
        padding: 12px 20px;
        border-radius: 10px;
        margin-bottom: 16px;
        background: #fee2e2;
        color: #b91c1c;
        border: 1px solid #fecaca;
        font-weight: 500;
        font-size: 14px;
    }

    @@media (max-width: 768px) {
        .filters-bar {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="admin-wrapper">
    <div class="page-header">
        <h2>Manage Reservations</h2>
        <div style="display: flex; gap: 10px; flex-wrap: wrap;">
            <a href="@Url.Action("Dashboard", "Admin")" class="btn-primary" style="background: #6b7280;">
                <i class="fa-regular fa-arrow-left"></i> Back
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="toast-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="toast-error">@TempData["Error"]</div>
    }

    <!-- Filters -->
    <form class="filters-bar" method="get" asp-controller="Admin" asp-action="Reservations">
        <div>
            <label class="form-label">Date From</label>
            <input type="date" class="form-control" name="fromDate" />
        </div>
        <div>
            <label class="form-label">Date To</label>
            <input type="date" class="form-control" name="toDate" />
        </div>
        <div>
            <label class="form-label">Status</label>
            <select class="form-control" name="status">
                <option value="">All Statuses</option>
                <option value="Confirmed">Confirmed</option>
                <option value="Pending">Pending</option>
                <option value="Cancelled">Cancelled</option>
                <option value="CheckedIn">Checked In</option>
                <option value="CheckedOut">Checked Out</option>
            </select>
        </div>
        <button type="submit" class="btn-filter"><i class="fa-solid fa-filter"></i> Apply</button>
    </form>

    <!-- Table -->
    <div class="admin-table-section">
        @if (reservations.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Guest</th>
                        <th>Property</th>
                        <th>Check-In</th>
                        <th>Check-Out</th>
                        <th>Guests</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in reservations)
                    {
                        <tr>
                            <td><strong>@r.ReservationNumber</strong></td>
                            <td>@r.UserName</td>
                            <td>@r.PropertyName</td>
                            <td>@r.CheckInDate.ToString("MMM dd, yyyy")</td>
                            <td>@r.CheckOutDate.ToString("MMM dd, yyyy")</td>
                            <td>@r.NumberOfGuests</td>
                            <td>@r.Currency @r.TotalPrice.ToString("N0")</td>
                            <td><span class="status-badge status-@r.Status">@r.Status</span></td>
                            <td>
                                <div class="action-group">
                                    <a href="@Url.Action("AdminDetails", "Reservation", new { id = r.Id })" class="btn-sm primary">View</a>
                                    <form asp-controller="Reservation" asp-action="UpdateStatus" method="post" style="display: inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@r.Id" />
                                        <select name="status" onchange="this.form.submit()" style="padding: 4px 8px; border-radius: 6px; border: 1px solid #e5e7eb; font-size: 12px;">
                                            <option value="Confirmed" selected="@(r.Status == "Confirmed")">Confirmed</option>
                                            <option value="Pending" selected="@(r.Status == "Pending")">Pending</option>
                                            <option value="CheckedIn" selected="@(r.Status == "CheckedIn")">Checked In</option>
                                            <option value="CheckedOut" selected="@(r.Status == "CheckedOut")">Checked Out</option>
                                            <option value="Cancelled" selected="@(r.Status == "Cancelled")">Cancelled</option>
                                        </select>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">
                <i class="fa-regular fa-calendar"></i>
                <p>No reservations found</p>
            </div>
        }
    </div>
</div>
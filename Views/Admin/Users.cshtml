@model IEnumerable<Hotel_Booking_System.Models.User>

@{
    ViewData["Title"] = "Manage Users";
    Layout = "_Layout";
    var users = Model ?? new List<Hotel_Booking_System.Models.User>();
}

<style>
    .admin-wrapper {
        max-width: 1200px;
        margin: 40px auto;
        padding: 0 20px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 12px;
    }

        .page-header h2 {
            font-size: 26px;
            font-weight: 700;
        }

    .admin-table-section {
        background: white;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        overflow-x: auto;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        min-width: 700px;
    }

    th {
        text-align: left;
        font-size: 12px;
        color: #6b7280;
        font-weight: 600;
        text-transform: uppercase;
        padding: 12px;
        border-bottom: 2px solid #f0f0f0;
    }

    td {
        padding: 12px;
        font-size: 14px;
        border-bottom: 1px solid #f3f4f6;
    }

    .user-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: #2563eb;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 14px;
    }

    .status-badge {
        padding: 4px 12px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 600;
    }

    .status-active {
        background: #dcfce7;
        color: #15803d;
    }

    .status-inactive {
        background: #fee2e2;
        color: #b91c1c;
    }

    .btn-sm {
        padding: 4px 12px;
        border-radius: 6px;
        border: 1px solid #e5e7eb;
        background: white;
        font-size: 12px;
        cursor: pointer;
        text-decoration: none;
        color: #4b5563;
        display: inline-block;
    }

        .btn-sm:hover {
            border-color: #2563eb;
            color: #2563eb;
        }

        .btn-sm.danger {
            border-color: #dc2626;
            color: #dc2626;
        }

            .btn-sm.danger:hover {
                background: #fee2e2;
            }

    .empty-state {
        text-align: center;
        padding: 40px 20px;
        color: #9ca3af;
    }

        .empty-state i {
            font-size: 48px;
            margin-bottom: 12px;
            display: block;
        }

    .toast-success {
        padding: 12px 20px;
        border-radius: 10px;
        margin-bottom: 16px;
        background: #dcfce7;
        color: #15803d;
        border: 1px solid #bbf7d0;
        font-weight: 500;
        font-size: 14px;
    }
</style>

<div class="admin-wrapper">
    <div class="page-header">
        <h2>Manage Users</h2>
        <a href="@Url.Action("Dashboard", "Admin")" class="btn-sm" style="padding: 8px 16px;">
            <i class="fa-regular fa-arrow-left"></i> Back
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="toast-success">@TempData["Success"]</div>
    }

    <div class="admin-table-section">
        @if (users.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Location</th>
                        <th>Joined</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in users)
                    {
                        <tr>
                            <td>
                                <div style="display: flex; align-items: center; gap: 10px;">
                                    <div class="user-avatar">@(user.FirstName?.FirstOrDefault() ?? 'U')</div>
                                    <div>
                                        <strong>@user.FullName</strong>
                                        @if (user.IsVerified)
                                        {
                                            <span style="font-size: 10px; color: #16a34a;">✓ Verified</span>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td>@user.Email</td>
                            <td>@user.PhoneNumber</td>
                            <td>@user.City, @user.Country</td>
                            <td>@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>
                                <span class="status-badge status-@(user.IsActive ? "active" : "inactive")">
                                    @(user.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td>
                                <form asp-controller="Admin" asp-action="ToggleUserStatus" method="post" style="display: inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="btn-sm @(user.IsActive ? "danger" : "")">
                                        @(user.IsActive ? "Deactivate" : "Activate")
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">
                <i class="fa-regular fa-user"></i>
                <p>No users found</p>
            </div>
        }
    </div>
</div>
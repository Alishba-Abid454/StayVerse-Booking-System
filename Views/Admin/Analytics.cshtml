@model Hotel_Booking_System.Models.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Analytics";
    Layout = "_Layout";
    var topProperties = ViewBag.TopProperties as IEnumerable<Hotel_Booking_System.Models.ViewModels.PropertyStatsViewModel> ?? new List<Hotel_Booking_System.Models.ViewModels.PropertyStatsViewModel>();
}

<style>
    .admin-wrapper {
        max-width: 1200px;
        margin: 40px auto;
        padding: 0 20px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 12px;
    }

        .page-header h2 {
            font-size: 26px;
            font-weight: 700;
        }

    .btn-sm {
        padding: 4px 12px;
        border-radius: 6px;
        border: 1px solid #e5e7eb;
        background: white;
        font-size: 12px;
        cursor: pointer;
        text-decoration: none;
        color: #4b5563;
        display: inline-block;
        padding: 8px 16px;
    }

        .btn-sm:hover {
            border-color: #2563eb;
            color: #2563eb;
        }

    .analytics-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        margin-bottom: 30px;
    }

    .analytics-card {
        background: white;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

        .analytics-card h3 {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 16px;
        }

    .stat-row {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        border-bottom: 1px solid #f3f4f6;
        font-size: 14px;
    }

        .stat-row:last-child {
            border-bottom: none;
        }

        .stat-row .label {
            color: #6b7280;
        }

        .stat-row .value {
            font-weight: 600;
        }

    .bar-cell {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .bar-track {
        flex: 1;
        height: 8px;
        background: #f0f0f0;
        border-radius: 4px;
        overflow: hidden;
    }

    .bar-fill {
        height: 100%;
        background: #2563eb;
        border-radius: 4px;
    }
</style>

<div class="admin-wrapper">
    <div class="page-header">
        <h2>Analytics</h2>
        <a href="@Url.Action("Dashboard", "Admin")" class="btn-sm">
            <i class="fa-regular fa-arrow-left"></i> Back
        </a>
    </div>

    <div class="analytics-grid">
        <!-- Property Type Distribution -->
        <div class="analytics-card">
            <h3>Property Type Distribution</h3>
            <div class="stat-row">
                <span class="label">Hotels</span>
                <span class="value">@Model?.HotelsCount.ToString("N0") ?? "0"</span>
            </div>
            <div class="stat-row">
                <span class="label">Apartments</span>
                <span class="value">@Model?.ApartmentsCount.ToString("N0") ?? "0"</span>
            </div>
            <div class="stat-row">
                <span class="label">Restaurants</span>
                <span class="value">@Model?.RestaurantsCount.ToString("N0") ?? "0"</span>
            </div>
            <div class="stat-row">
                <span class="label">Total Properties</span>
                <span class="value">@Model?.TotalProperties.ToString("N0") ?? "0"</span>
            </div>
        </div>

        <!-- Quick Stats -->
        <div class="analytics-card">
            <h3>Quick Stats</h3>
            <div class="stat-row">
                <span class="label">Occupancy Rate</span>
                <span class="value">@(Model?.OccupancyRate.ToString("F0") ?? "0")%</span>
            </div>
            <div class="stat-row">
                <span class="label">Average Rating</span>
                <span class="value">@(Model?.AverageRating.ToString("F1") ?? "0.0") ⭐</span>
            </div>
            <div class="stat-row">
                <span class="label">Total Revenue</span>
                <span class="value">$@(Model?.TotalRevenue.ToString("N0") ?? "0")</span>
            </div>
            <div class="stat-row">
                <span class="label">Monthly Revenue</span>
                <span class="value">$@(Model?.MonthlyRevenue.ToString("N0") ?? "0")</span>
            </div>
        </div>
    </div>

    <!-- Top Performing Properties -->
    @if (topProperties.Any())
    {
        <div class="analytics-card">
            <h3>Top Performing Properties</h3>
            @foreach (var p in topProperties)
            {
                <div class="stat-row">
                    <span class="label">@p.Name</span>
                    <span class="value" style="display: flex; align-items: center; gap: 12px;">
                        <span>@p.Bookings bookings</span>
                        <span style="color: #2563eb;">$@p.Revenue.ToString("N0")</span>
                        <span style="font-size: 13px; color: #6b7280;">@p.OccupancyRate.ToString("F0")%</span>
                    </span>
                </div>
            }
        </div>
    }
</div>
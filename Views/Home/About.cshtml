                </div>
                <div class="member-name">Ahmed Hassan</div>
                <div class="member-role">CEO & Founder</div>
                <div class="member-bio">Leading the vision for seamless restaurant experiences with 10+ years in hospitality tech</div>
            </div>
            <div class="team-member">
                <div class="member-image">
                    <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&w=400&q=70" alt="CTO" loading="lazy" />
                </div>
                <div class="member-name">Sarah Khan</div>
                <div class="member-role">CTO</div>
                <div class="member-bio">Building the AI-powered reservation engine with expertise in machine learning</div>
            </div>
            <div class="team-member">
                <div class="member-image">
                    <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?auto=format&fit=crop&w=400&q=70" alt="Head of Operations" loading="lazy" />
                </div>
                <div class="member-name">Fatima Ali</div>
                <div class="member-role">Head of Operations</div>
                <div class="member-bio">Connecting restaurants with technology and driving partnerships globally</div>
            </div>
        </div>
    </div>
</section>

<!-- ===== CTA ===== -->
<section class="cta-section">
    <div class="cta-card">
        <div class="cta-content">
            <h3>Ready to book your next table?</h3>
            <p>Search live availability or just chat with our assistant — either way, you'll be seated in minutes.</p>
        </div>
        <a href="@Url.Action("Book", "Reservation")" class="cta-button">
            <i class="fa-regular fa-calendar-check"></i> Book Now
        </a>
    </div>
</section>

<div class="footer-spacing"></div>

@model IEnumerable<Hotel_Booking_System.Models.ViewModels.PropertyViewModel>

@{
    ViewData["Title"] = "All Properties";
    var properties = Model ?? new List<Hotel_Booking_System.Models.ViewModels.PropertyViewModel>();
}

<style>
    .properties-header {
        background: linear-gradient(135deg, #1e3a5f, #2563eb);
        padding: 60px 20px 40px;
        text-align: center;
        color: white;
        margin-bottom: 40px;
    }

        .properties-header h1 {
            font-size: 36px;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .properties-header p {
            font-size: 16px;
            opacity: 0.9;
            max-width: 600px;
            margin: 0 auto;
        }

    .filter-bar {
        max-width: 1100px;
        margin: -24px auto 40px;
        padding: 0 20px;
        position: relative;
        z-index: 10;
    }

    .filter-bar-inner {
        background: white;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.12);
        padding: 18px 24px;
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        align-items: center;
    }

    .filter-btn {
        padding: 8px 20px;
        border: 1.5px solid #e5e7eb;
        border-radius: 8px;
        background: white;
        color: #4b5563;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.2s;
    }

        .filter-btn:hover {
            border-color: #2563eb;
            color: #2563eb;
        }

        .filter-btn.active {
            background: #2563eb;
            border-color: #2563eb;
            color: white;
        }

    .properties-grid {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 20px 60px;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 28px;
    }

    .property-card {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        transition: transform 0.3s, box-shadow 0.3s;
    }

        .property-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 32px rgba(0,0,0,0.12);
        }

    .property-img-wrapper {
        position: relative;
        height: 200px;
        overflow: hidden;
    }

        .property-img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .property-type-badge {
        position: absolute;
        top: 12px;
        right: 12px;
        padding: 4px 14px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .badge-hotel {
        background: #2563eb;
        color: white;
    }

    .badge-apartment {
        background: #059669;
        color: white;
    }

    .badge-resort {
        background: #7c3aed;
        color: white;
    }

    .badge-lodge {
        background: #d97706;
        color: white;
    }

    .badge-restaurant {
        background: #d97706;
        color: white;
    }

    .property-info {
        padding: 18px 20px 20px;
    }

    .property-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 4px;
    }

    .property-info h3 {
        font-size: 18px;
        font-weight: 600;
        margin: 0;
    }

    .rating-stars {
        color: #f59e0b;
        font-size: 14px;
        letter-spacing: 1px;
    }

    .property-location {
        font-size: 13px;
        color: #6b7280;
        margin-bottom: 8px;
    }

    .property-description {
        font-size: 13px;
        color: #4b5563;
        line-height: 1.5;
        margin-bottom: 12px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .property-price {
        font-size: 18px;
        font-weight: 700;
        color: #1a1a1a;
        margin-bottom: 12px;
    }

    .property-amenities {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 14px;
    }

    .amenity-tag {
        padding: 4px 12px;
        background: #f3f4f6;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 500;
        color: #4b5563;
    }

    .btn-book {
        display: inline-block;
        padding: 10px 24px;
        background: #2563eb;
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        text-decoration: none;
        transition: background 0.2s;
        width: 100%;
        text-align: center;
    }

        .btn-book:hover {
            background: #1d4ed8;
        }

    .no-results {
        grid-column: 1 / -1;
        text-align: center;
        padding: 60px 20px;
        color: #6b7280;
    }

        .no-results h3 {
            font-size: 20px;
            color: #1a1a1a;
            margin-bottom: 8px;
        }

        .no-results i {
            font-size: 48px;
            color: #d1d5db;
            margin-bottom: 16px;
        }

    /* Responsive */
    @@media (max-width: 1024px) {
        .properties-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 640px) {
        .properties-grid {
            grid-template-columns: 1fr;
        }

        .properties-header h1 {
            font-size: 28px;
        }

        .filter-bar-inner {
            justify-content: center;
        }
    }
</style>

<!-- Header -->
<div class="properties-header">
    <h1>🏨 All Properties</h1>
    <p>Browse our curated collection of hotels, apartments, and restaurants</p>
</div>

<!-- Filter Bar -->
<div class="filter-bar">
    <div class="filter-bar-inner">
        <button class="filter-btn active" data-filter="all" onclick="filterProperties('all')">All</button>
        <button class="filter-btn" data-filter="Hotel" onclick="filterProperties('Hotel')">🏨 Hotels</button>
        <button class="filter-btn" data-filter="Apartment" onclick="filterProperties('Apartment')">🏠 Apartments</button>
        <button class="filter-btn" data-filter="Resort" onclick="filterProperties('Resort')">🌴 Resorts</button>
        <button class="filter-btn" data-filter="Lodge" onclick="filterProperties('Lodge')">🏔️ Lodges</button>
        <span style="margin-left: auto; font-size: 14px; color: #6b7280;" id="resultCount">@properties.Count() properties found</span>
    </div>
</div>

<!-- Properties Grid -->
<div class="properties-grid" id="propertiesGrid">
    @if (properties.Any())
    {
        @foreach (var property in properties)
        {
            var badgeClass = property.Type?.ToLower() switch
            {
                "hotel" => "badge-hotel",
                "apartment" => "badge-apartment",
                "resort" => "badge-resort",
                "lodge" => "badge-lodge",
                _ => "badge-hotel"
            };

            <div class="property-card" data-type="@property.Type">
                <div class="property-img-wrapper">
                    <img src="@(property.ImageUrl ?? "/images/default-property.jpg")" alt="@property.Name" />
                    <span class="property-type-badge @badgeClass">@property.Type</span>
                </div>
                <div class="property-info">
                    <div class="property-top">
                        <h3>@property.Name</h3>
                        <span class="rating-stars">
                            @for (int i = 0; i < (int)Math.Round(property.Rating / 2); i++)
                            {
                                <span>★</span>
                            }
                        </span>
                    </div>
                    <div class="property-location">📍 @property.Location</div>
                    <div class="property-description">@property.Description</div>
                    <div class="property-price">@property.Price</div>
                    <div class="property-amenities">
                        @if (property.Amenities != null && property.Amenities.Any())
                        {
                            @foreach (var amenity in property.Amenities.Take(4))
                            {
                                <span class="amenity-tag">@amenity</span>
                            }
                            if (property.Amenities.Count() > 4)
                            {
                                <span class="amenity-tag">+@(property.Amenities.Count() - 4) more</span>
                            }
                        }
                    </div>
                    <a href="@Url.Action("Details", "Properties", new { id = property.Id })" class="btn-book">
                        View Details
                    </a>
                </div>
            </div>
        }
    }
    else
    {
        <div class="no-results">
            <i class="fa-regular fa-building"></i>
            <h3>No properties found</h3>
            <p>Try adjusting your search criteria or check back later.</p>
        </div>
    }
</div>

<script>
    function filterProperties(type) {
        // Update active button
        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.classList.remove('active');
        });
        document.querySelector(`[data-filter="${type}"]`)?.classList.add('active');

        // Filter cards
        const cards = document.querySelectorAll('.property-card');
        let visibleCount = 0;

        cards.forEach(card => {
            if (type === 'all' || card.dataset.type === type) {
                card.style.display = 'block';
                visibleCount++;
            } else {
                card.style.display = 'none';
            }
        });

        // Update result count
        document.getElementById('resultCount').textContent =
            visibleCount + ' property' + (visibleCount !== 1 ? 's' : '') + ' found';
    }
</script>
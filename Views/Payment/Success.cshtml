@model Hotel_Booking_System.Models.ViewModels.PaymentViewModel
@{
    ViewData["Title"] = "Payment Successful";
    Layout = "_Layout";
    var reservation = ViewBag.Reservation as Hotel_Booking_System.Models.ViewModels.ReservationViewModel;
}

<style>
    /* ===== Animation Keyframes ===== */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes scaleIn {
        from {
            opacity: 0;
            transform: scale(0.8);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    @@keyframes confetti {
        0% {
            transform: translateY(0) rotate(0deg);
            opacity: 1;
        }

        100% {
            transform: translateY(-100px) rotate(720deg);
            opacity: 0;
        }
    }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-10px);
        }
    }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.05);
        }
    }

    @@keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    /* ===== Main Container ===== */
    .success-container {
        max-width: 620px;
        margin: 40px auto;
        padding: 0 20px;
        animation: fadeInUp 0.6s ease-out;
    }

    .success-card {
        background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
        border-radius: 24px;
        padding: 50px 45px;
        box-shadow: 0 20px 60px rgba(15, 23, 42, 0.12);
        border: 1px solid rgba(37, 99, 235, 0.08);
        position: relative;
        overflow: hidden;
    }

        /* ===== Decorative Elements ===== */
        .success-card::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -30%;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(37, 99, 235, 0.05), transparent);
            border-radius: 50%;
            pointer-events: none;
        }

        .success-card::after {
            content: '';
            position: absolute;
            bottom: -40%;
            left: -20%;
            width: 250px;
            height: 250px;
            background: radial-gradient(circle, rgba(22, 163, 74, 0.05), transparent);
            border-radius: 50%;
            pointer-events: none;
        }

    /* ===== Top Decorative Bar ===== */
    .top-bar {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, #2563eb, #7c3aed, #ec4899, #2563eb);
        background-size: 300% 100%;
        animation: gradientMove 3s ease infinite;
    }

    @@keyframes gradientMove {
        0%, 100% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }
    }

    /* ========================================
           ✅ NEW: LOGO/ICON SECTION (Replaced Green Box)
           ======================================== */
    .logo-section {
        text-align: center;
        margin-bottom: 24px;
        animation: scaleIn 0.8s ease-out 0.2s both;
    }

    .logo-wrapper {
        display: inline-block;
        position: relative;
    }

    .logo-icon {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
        box-shadow: 0 8px 40px rgba(37, 99, 235, 0.35);
        position: relative;
        transition: all 0.3s ease;
        animation: pulse 2s ease-in-out infinite;
    }

        .logo-icon:hover {
            transform: scale(1.05);
            box-shadow: 0 12px 50px rgba(37, 99, 235, 0.45);
        }

        /* ✅ Brand Logo Inside */
        .logo-icon .brand-logo {
            font-size: 42px;
            font-weight: 800;
            color: white;
            letter-spacing: -1px;
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.15);
            font-family: 'Playfair Display', serif;
        }

            .logo-icon .brand-logo i {
                font-size: 36px;
                margin-right: 4px;
            }

    /* ✅ Checkmark Overlay */
    .check-overlay {
        position: absolute;
        bottom: -2px;
        right: -2px;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: #10b981;
        border: 3px solid white;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.4);
        animation: scaleIn 1s ease-out 0.5s both;
    }

        .check-overlay i {
            font-size: 16px;
            color: white;
        }

    /* ✅ Pulse Ring Effect */
    .pulse-ring {
        position: absolute;
        top: -10px;
        left: -10px;
        right: -10px;
        bottom: -10px;
        border-radius: 50%;
        border: 2px solid rgba(37, 99, 235, 0.15);
        animation: ringPulse 2s ease-out infinite;
    }

        .pulse-ring:nth-child(2) {
            animation-delay: 1s;
        }

    @@keyframes ringPulse {
        0% {
            transform: scale(1);
            opacity: 0.8;
        }

        100% {
            transform: scale(1.3);
            opacity: 0;
        }
    }

    /* ===== Title Section ===== */
    .title-section {
        text-align: center;
        margin-bottom: 28px;
        position: relative;
        z-index: 1;
    }

    .badge-success {
        display: inline-block;
        padding: 4px 16px;
        background: #dcfce7;
        color: #15803d;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 12px;
    }

    .title-section h1 {
        font-size: 30px;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 6px;
        background: linear-gradient(135deg, #0f172a, #2563eb);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .title-section .subtitle {
        color: #6b7280;
        font-size: 16px;
        -webkit-text-fill-color: initial;
    }

        .title-section .subtitle i {
            color: #2563eb;
            margin: 0 4px;
        }

    /* ===== Payment Details ===== */
    .payment-details {
        background: white;
        border-radius: 16px;
        padding: 24px 28px;
        margin-bottom: 28px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
        border: 1px solid #f1f5f9;
        position: relative;
        z-index: 1;
    }

        .payment-details .detail-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            border-bottom: 1px solid #f1f5f9;
        }

            .payment-details .detail-row:last-child {
                border-bottom: none;
            }

    .detail-row .label {
        display: flex;
        align-items: center;
        gap: 10px;
        color: #6b7280;
        font-size: 14px;
        font-weight: 500;
    }

        .detail-row .label i {
            color: #2563eb;
            font-size: 16px;
            width: 20px;
            text-align: center;
        }

    .detail-row .value {
        font-weight: 600;
        color: #0f172a;
        font-size: 14px;
    }

        .detail-row .value.highlight {
            color: #2563eb;
            font-size: 18px;
            font-weight: 700;
        }

    .detail-row .status-badge {
        padding: 4px 16px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        background: #dcfce7;
        color: #15803d;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .status-badge i {
        font-size: 10px;
    }

    /* ===== Email Confirmation Notice ===== */
    .email-notice {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 20px;
        background: #eff6ff;
        border-radius: 12px;
        margin-bottom: 24px;
        border-left: 4px solid #2563eb;
        position: relative;
        z-index: 1;
    }

        .email-notice i {
            color: #2563eb;
            font-size: 20px;
        }

        .email-notice p {
            margin: 0;
            font-size: 13px;
            color: #1e40af;
        }

            .email-notice p strong {
                font-weight: 700;
            }

    /* ===== Buttons ===== */
    .btn-group {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
        position: relative;
        z-index: 1;
    }

    .btn-primary {
        padding: 14px 36px;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: white;
        border: none;
        border-radius: 12px;
        font-weight: 700;
        font-size: 15px;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        box-shadow: 0 4px 20px rgba(37, 99, 235, 0.3);
    }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 30px rgba(37, 99, 235, 0.4);
            color: white;
        }

        .btn-primary i {
            font-size: 16px;
        }

    .btn-secondary {
        padding: 14px 36px;
        background: white;
        color: #4b5563;
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        font-weight: 600;
        font-size: 15px;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

        .btn-secondary:hover {
            border-color: #2563eb;
            color: #2563eb;
            transform: translateY(-3px);
            box-shadow: 0 4px 20px rgba(37, 99, 235, 0.1);
        }

        .btn-secondary i {
            font-size: 16px;
        }

    /* ===== Footer Text ===== */
    .footer-note {
        text-align: center;
        margin-top: 20px;
        color: #9ca3af;
        font-size: 13px;
        position: relative;
        z-index: 1;
    }

        .footer-note i {
            color: #10b981;
            margin-right: 4px;
        }

    /* ===== Responsive ===== */
    @@media (max-width: 480px) {
        .success-card {
            padding: 30px 20px;
        }

        .logo-icon {
            width: 80px;
            height: 80px;
        }

            .logo-icon .brand-logo {
                font-size: 32px;
            }

                .logo-icon .brand-logo i {
                    font-size: 28px;
                }

        .check-overlay {
            width: 28px;
            height: 28px;
        }

            .check-overlay i {
                font-size: 12px;
            }

        .title-section h1 {
            font-size: 24px;
        }

        .payment-details {
            padding: 16px 18px;
        }

        .detail-row {
            flex-direction: column;
            align-items: flex-start;
            gap: 4px;
        }

        .btn-group {
            flex-direction: column;
        }

        .btn-primary, .btn-secondary {
            justify-content: center;
            padding: 14px 24px;
        }

        .confetti {
            display: none;
        }

        .email-notice {
            flex-direction: column;
            text-align: center;
        }
    }
</style>

<div class="success-container">
    <div class="success-card">
        <!-- Top Bar -->
        <div class="top-bar"></div>

        <!-- ✅ NEW: Logo/Icon Section (Replaced Green Box) -->
        <div class="logo-section">
            <div class="logo-wrapper">
                <!-- Pulse Rings -->
                <div class="pulse-ring"></div>
                <div class="pulse-ring"></div>

                <!-- Main Logo Icon -->
                <div class="logo-icon">
                    <span class="brand-logo">
                        <i class="fas fa-utensils"></i>SV
                    </span>
                    <!-- Checkmark Overlay -->
                    <div class="check-overlay">
                        <i class="fas fa-check"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Title -->
        <div class="title-section">
            <div class="badge-success">
                <i class="fas fa-check-circle"></i> Confirmed
            </div>
            <h1>Payment Successful! 🎉</h1>
            <p class="subtitle">
                <i class="fas fa-calendar-check"></i>
                Your booking has been confirmed
                <i class="fas fa-check-circle" style="color:#10b981;"></i>
            </p>
        </div>

        <!-- Payment Details -->
        <div class="payment-details">
            <div class="detail-row">
                <span class="label"><i class="fas fa-hashtag"></i> Reservation #</span>
                <span class="value">@Model.ReservationNumber</span>
            </div>
            <div class="detail-row">
                <span class="label"><i class="fas fa-receipt"></i> Transaction ID</span>
                <span class="value">@Model.TransactionId</span>
            </div>
            <div class="detail-row">
                <span class="label"><i class="fas fa-credit-card"></i> Payment Method</span>
                <span class="value">@Model.PaymentMethod</span>
            </div>
            <div class="detail-row">
                <span class="label"><i class="fas fa-money-bill-wave"></i> Amount Paid</span>
                <span class="value highlight">@Model.Amount.ToString("C")</span>
            </div>
            <div class="detail-row">
                <span class="label"><i class="fas fa-shield-alt"></i> Status</span>
                <span class="status-badge">
                    <i class="fas fa-check-circle"></i> @Model.Status
                </span>
            </div>
        </div>

        <!-- Email Notice -->
        <div class="email-notice">
            <i class="fas fa-envelope"></i>
            <p>
                <strong>Confirmation email sent!</strong>
                A confirmation email has been sent to your registered email address.
            </p>
        </div>

        <!-- Buttons -->
        <div class="btn-group">
            <a href="@Url.Action("Details", "Reservation", new { id = Model.ReservationId })" class="btn-primary">
                <i class="fas fa-eye"></i> View Reservation
            </a>
            <a href="@Url.Action("Index", "Home")" class="btn-secondary">
                <i class="fas fa-home"></i> Return Home
            </a>
        </div>

        <!-- Footer -->
        <div class="footer-note">
            <i class="fas fa-lock"></i>
            Secure transaction · Need help? <a href="@Url.Action("Index", "Chat")" style="color:#2563eb; text-decoration:none; font-weight:600;">Chat with our AI assistant</a>
        </div>
    </div>
</div>
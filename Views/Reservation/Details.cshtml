@model Hotel_Booking_System.Models.ViewModels.ReservationViewModel

@{
    ViewData["Title"] = $"Reservation {Model?.ReservationNumber}";
}

<style>
    /* ===== Animations ===== */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateX(-20px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.05);
        }
    }

    /* ===== Main Container ===== */
    .details-wrapper {
        max-width: 820px;
        margin: 40px auto;
        padding: 0 20px;
        animation: fadeInUp 0.6s ease-out;
    }

    /* ===== Card ===== */
    .detail-card {
        background: linear-gradient(135deg, #ffffff 0%, #fafbfc 100%);
        border-radius: 24px;
        padding: 40px 42px;
        box-shadow: 0 20px 60px rgba(15, 23, 42, 0.1);
        border: 1px solid rgba(37, 99, 235, 0.06);
        position: relative;
        overflow: hidden;
    }

        .detail-card::before {
            content: '';
            position: absolute;
            top: -30%;
            right: -20%;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(37, 99, 235, 0.04), transparent);
            border-radius: 50%;
            pointer-events: none;
        }

        .detail-card::after {
            content: '';
            position: absolute;
            bottom: -30%;
            left: -10%;
            width: 200px;
            height: 200px;
            background: radial-gradient(circle, rgba(16, 185, 129, 0.04), transparent);
            border-radius: 50%;
            pointer-events: none;
        }

    /* ===== Top Bar ===== */
    .top-bar {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, #2563eb, #7c3aed, #ec4899, #2563eb);
        background-size: 300% 100%;
        animation: gradientMove 3s ease infinite;
    }

    @@keyframes gradientMove {
        0%, 100% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }
    }

    /* ===== Header ===== */
    .detail-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 28px;
        padding-bottom: 20px;
        border-bottom: 2px solid #f0f4f8;
        flex-wrap: wrap;
        gap: 12px;
        position: relative;
        z-index: 1;
    }

        .detail-header .title-group {
            display: flex;
            align-items: center;
            gap: 14px;
        }

            .detail-header .title-group .icon-wrapper {
                width: 48px;
                height: 48px;
                border-radius: 14px;
                background: linear-gradient(135deg, #2563eb, #1d4ed8);
                display: flex;
                align-items: center;
                justify-content: center;
                box-shadow: 0 4px 15px rgba(37, 99, 235, 0.25);
            }

                .detail-header .title-group .icon-wrapper i {
                    font-size: 20px;
                    color: white;
                }

        .detail-header h1 {
            font-size: 24px;
            font-weight: 700;
            color: #0f172a;
            margin: 0;
        }

            .detail-header h1 small {
                font-size: 14px;
                font-weight: 400;
                color: #6b7280;
                display: block;
                margin-top: 2px;
            }

    /* ===== Status Badge ===== */
    .status-badge {
        padding: 8px 24px;
        border-radius: 50px;
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        animation: pulse 2s ease-in-out infinite;
    }

    .status-Confirmed {
        background: #dcfce7;
        color: #15803d;
        box-shadow: 0 2px 12px rgba(22, 163, 74, 0.15);
    }

    .status-Pending {
        background: #fef3c7;
        color: #92400e;
        box-shadow: 0 2px 12px rgba(217, 119, 6, 0.15);
    }

    .status-CheckedIn {
        background: #dbeafe;
        color: #1d4ed8;
        box-shadow: 0 2px 12px rgba(37, 99, 235, 0.15);
    }

    .status-CheckedOut {
        background: #f1f5f9;
        color: #475569;
        box-shadow: 0 2px 12px rgba(71, 85, 105, 0.1);
    }

    .status-Cancelled {
        background: #fee2e2;
        color: #991b1b;
        box-shadow: 0 2px 12px rgba(220, 38, 38, 0.15);
    }

    .status-badge i {
        font-size: 14px;
    }

    /* ===== Details Grid ===== */
    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px 40px;
        position: relative;
        z-index: 1;
    }

    .detail-item {
        padding: 14px 0;
        border-bottom: 1px solid #f1f5f9;
        transition: all 0.3s ease;
    }

        .detail-item:hover {
            border-bottom-color: #2563eb;
        }

        .detail-item .label {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            font-weight: 600;
            color: #9ca3af;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 4px;
        }

            .detail-item .label i {
                color: #2563eb;
                font-size: 13px;
                width: 16px;
            }

        .detail-item .value {
            font-size: 16px;
            font-weight: 600;
            color: #0f172a;
            padding-left: 24px;
        }

            .detail-item .value.highlight {
                color: #2563eb;
                font-size: 20px;
            }

            .detail-item .value .paid {
                color: #16a34a;
            }

            .detail-item .value .unpaid {
                color: #f59e0b;
            }

            .detail-item .value i {
                margin-right: 6px;
            }

    .detail-full {
        grid-column: 1 / -1;
    }

    /* ===== Special Requests Box ===== */
    .requests-box {
        background: #f8fafc;
        border-radius: 12px;
        padding: 16px 20px;
        border-left: 4px solid #2563eb;
        margin-top: 4px;
    }

        .requests-box p {
            margin: 0;
            font-size: 14px;
            color: #4b5563;
        }

    /* ===== Actions ===== */
    .detail-actions {
        margin-top: 30px;
        padding-top: 24px;
        border-top: 2px solid #f0f4f8;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        position: relative;
        z-index: 1;
    }

    .btn-back {
        padding: 12px 24px;
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        background: white;
        text-decoration: none;
        color: #4b5563;
        font-weight: 600;
        font-size: 14px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
    }

        .btn-back:hover {
            border-color: #2563eb;
            color: #2563eb;
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(37, 99, 235, 0.08);
        }

    .btn-cancel {
        padding: 12px 24px;
        background: linear-gradient(135deg, #dc2626, #b91c1c);
        color: white;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(220, 38, 38, 0.25);
    }

        .btn-cancel:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(220, 38, 38, 0.35);
        }

    .btn-print {
        padding: 12px 24px;
        background: white;
        color: #2563eb;
        border: 2px solid #2563eb;
        border-radius: 12px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
    }

        .btn-print:hover {
            background: #eff6ff;
            transform: translateY(-2px);
        }

    /* ===== Modal ===== */
    .modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(8px);
        z-index: 1000;
        align-items: center;
        justify-content: center;
        animation: fadeInUp 0.3s ease-out;
    }

        .modal-overlay.active {
            display: flex !important;
        }

    .modal-box {
        background: white;
        border-radius: 20px;
        padding: 36px 32px;
        max-width: 440px;
        width: 90%;
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.25);
        animation: slideIn 0.3s ease-out;
    }

        .modal-box .modal-icon {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            background: #fee2e2;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px;
        }

            .modal-box .modal-icon i {
                font-size: 28px;
                color: #dc2626;
            }

        .modal-box h3 {
            text-align: center;
            font-size: 20px;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 8px;
        }

        .modal-box p {
            text-align: center;
            font-size: 14px;
            color: #6b7280;
            margin-bottom: 20px;
            line-height: 1.6;
        }

        .modal-box .form-group {
            margin-bottom: 16px;
        }

            .modal-box .form-group label {
                display: block;
                font-size: 13px;
                font-weight: 600;
                color: #4b5563;
                margin-bottom: 6px;
            }

            .modal-box .form-group input {
                width: 100%;
                padding: 12px 16px;
                border: 1.5px solid #e5e7eb;
                border-radius: 10px;
                font-size: 14px;
                transition: all 0.3s ease;
            }

                .modal-box .form-group input:focus {
                    outline: none;
                    border-color: #2563eb;
                    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
                }

    .modal-actions {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
        margin-top: 20px;
    }

        .modal-actions .btn-keep {
            padding: 10px 24px;
            border: 2px solid #e5e7eb;
            border-radius: 10px;
            background: white;
            cursor: pointer;
            font-weight: 600;
            font-size: 14px;
            color: #4b5563;
            transition: all 0.3s ease;
        }

            .modal-actions .btn-keep:hover {
                border-color: #2563eb;
                color: #2563eb;
            }

        .modal-actions .btn-confirm-cancel {
            padding: 10px 24px;
            background: linear-gradient(135deg, #dc2626, #b91c1c);
            color: white;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
            font-size: 14px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(220, 38, 38, 0.25);
        }

            .modal-actions .btn-confirm-cancel:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 25px rgba(220, 38, 38, 0.35);
            }

    /* ===== Not Found ===== */
    .not-found {
        text-align: center;
        padding: 80px 20px;
        animation: fadeInUp 0.6s ease-out;
    }

        .not-found .icon {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
        }

            .not-found .icon i {
                font-size: 36px;
                color: #94a3b8;
            }

        .not-found h2 {
            font-size: 24px;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 8px;
        }

        .not-found p {
            color: #6b7280;
            margin-bottom: 24px;
        }

    /* ===== Responsive ===== */
    @@media (max-width: 650px) {
        .detail-card {
            padding: 24px 20px;
        }

        .detail-grid {
            grid-template-columns: 1fr;
            gap: 8px;
        }

        .detail-header {
            flex-direction: column;
            align-items: flex-start;
        }

            .detail-header .title-group {
                width: 100%;
            }

        .status-badge {
            align-self: flex-start;
        }

        .detail-actions {
            flex-direction: column;
        }

            .detail-actions a, .detail-actions button {
                justify-content: center;
            }

        .modal-box {
            padding: 24px 20px;
        }

        .modal-actions {
            flex-direction: column;
        }

            .modal-actions button {
                justify-content: center;
            }
    }
</style>

@if (Model != null)
{
    <div class="details-wrapper">
        <div class="detail-card">
            <!-- Top Bar -->
            <div class="top-bar"></div>

            <!-- Header -->
            <div class="detail-header">
                <div class="title-group">
                    <div class="icon-wrapper">
                        <i class="fas fa-receipt"></i>
                    </div>
                    <div>
                        <h1>
                            Reservation Details
                            <small>@Model.ReservationNumber</small>
                        </h1>
                    </div>
                </div>
                <span class="status-badge status-@(Model.Status ?? "Pending")">
                    <i class="fas fa-@(Model.Status == "Confirmed" ? "check-circle" : Model.Status == "Pending" ? "clock" : Model.Status == "Cancelled" ? "times-circle" : "info-circle")"></i>
                    @Model.Status
                </span>
            </div>

            <!-- Details Grid -->
            <div class="detail-grid">
                <div class="detail-item">
                    <div class="label"><i class="fas fa-building"></i> Property</div>
                    <div class="value">@Model.PropertyName</div>
                </div>

                <div class="detail-item">
                    <div class="label"><i class="fas fa-bed"></i> Room Type</div>
                    <div class="value">@(Model.RoomTypeName ?? "Not specified")</div>
                </div>

                <div class="detail-item">
                    <div class="label"><i class="fas fa-calendar-check"></i> Check-In</div>
                    <div class="value">@Model.CheckInDate.ToString("dddd, MMMM dd, yyyy")</div>
                </div>

                <div class="detail-item">
                    <div class="label"><i class="fas fa-calendar-times"></i> Check-Out</div>
                    <div class="value">@Model.CheckOutDate.ToString("dddd, MMMM dd, yyyy")</div>
                </div>

                <div class="detail-item">
                    <div class="label"><i class="fas fa-moon"></i> Nights</div>
                    <div class="value">@Model.NumberOfNights night@(Model.NumberOfNights > 1 ? "s" : "")</div>
                </div>

                <div class="detail-item">
                    <div class="label"><i class="fas fa-users"></i> Guests</div>
                    <div class="value">@Model.NumberOfGuests guest@(Model.NumberOfGuests > 1 ? "s" : "")</div>
                </div>

                <div class="detail-item">
                    <div class="label"><i class="fas fa-door-open"></i> Rooms</div>
                    <div class="value">@Model.NumberOfRooms room@(Model.NumberOfRooms > 1 ? "s" : "")</div>
                </div>

                <div class="detail-item">
                    <div class="label"><i class="fas fa-dollar-sign"></i> Total Price</div>
                    <div class="value highlight">@Model.Currency @Model.TotalPrice.ToString("N0")</div>
                </div>

                <div class="detail-item">
                    <div class="label"><i class="fas fa-tag"></i> Price Per Night</div>
                    <div class="value">@Model.Currency @Model.PricePerNight.ToString("N0")</div>
                </div>

                <div class="detail-item">
                    <div class="label"><i class="fas fa-credit-card"></i> Payment Status</div>
                    <div class="value">
                        @if (Model.IsPaid)
                        {
                            <span class="paid"><i class="fas fa-check-circle"></i> Paid</span>
                        }
                        else
                        {
                            <span class="unpaid"><i class="fas fa-clock"></i> Unpaid</span>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.SpecialRequests))
                {
                    <div class="detail-item detail-full">
                        <div class="label"><i class="fas fa-pen"></i> Special Requests</div>
                        <div class="requests-box">
                            <p>📝 @Model.SpecialRequests</p>
                        </div>
                    </div>
                }

                @if (Model.Status == "Cancelled" && !string.IsNullOrEmpty(Model.CancellationReason))
                {
                    <div class="detail-item detail-full">
                        <div class="label"><i class="fas fa-info-circle"></i> Cancellation Reason</div>
                        <div class="value" style="color:#dc2626;">@Model.CancellationReason</div>
                    </div>
                }

                <div class="detail-item detail-full">
                    <div class="label"><i class="fas fa-clock"></i> Booking Date</div>
                    <div class="value">@Model.CreatedAt.ToString("dddd, MMMM dd, yyyy 'at' HH:mm")</div>
                </div>
            </div>

            <!-- Actions -->
            <div class="detail-actions">
                <a href="@Url.Action("Index", "Home")" class="btn-back">
                    <i class="fas fa-arrow-left"></i> Back to Home
                </a>
                @if (Model.CanCancel)
                {
                    <button class="btn-cancel" onclick="openCancelModal(@Model.Id)">
                        <i class="fas fa-times"></i> Cancel Booking
                    </button>
                }

            </div>
        </div>
    </div>

    <!-- ===== Cancel Modal ===== -->
    <div class="modal-overlay" id="cancelModal">
        <div class="modal-box">
            <div class="modal-icon">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <h3>Cancel Reservation</h3>
            <p>Are you sure you want to cancel this reservation? This action cannot be undone.</p>
            <form asp-action="CancelPost" asp-controller="Reservation" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="cancelReservationId" />
                <div class="form-group">
                    <label for="reason">Reason for cancellation</label>
                    <input type="text" id="reason" name="reason" placeholder="Why are you cancelling? (Optional)" />
                </div>
                <div class="modal-actions">
                    <button type="button" class="btn-keep" onclick="closeCancelModal()">
                        <i class="fas fa-arrow-left"></i> Keep Booking
                    </button>
                    <button type="submit" class="btn-confirm-cancel">
                        <i class="fas fa-trash"></i> Yes, Cancel
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function openCancelModal(reservationId) {
            document.getElementById('cancelReservationId').value = reservationId;
            document.getElementById('cancelModal').classList.add('active');
        }

        function closeCancelModal() {
            document.getElementById('cancelModal').classList.remove('active');
        }

        document.getElementById('cancelModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                closeCancelModal();
            }
        });
    </script>
}
else
{
    <div class="not-found">
        <div class="icon">
            <i class="fas fa-calendar-times"></i>
        </div>
        <h2>Reservation Not Found</h2>
        <p>The reservation you're looking for doesn't exist or you don't have permission to view it.</p>
        <a href="@Url.Action("MyReservations", "Reservation")" class="btn-back">
            <i class="fas fa-arrow-left"></i> Back to My Reservations
        </a>
    </div>
}
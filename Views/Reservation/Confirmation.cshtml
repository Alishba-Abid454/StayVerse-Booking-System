@model Hotel_Booking_System.Models.ViewModels.ReservationViewModel

@{
    ViewData["Title"] = "Booking Confirmed!";
}

<style>
    .confirmation-wrapper {
        max-width: 600px;
        margin: 60px auto;
        padding: 0 20px;
        text-align: center;
    }

    .confirmation-card {
        background: white;
        border-radius: 20px;
        padding: 48px 40px;
        box-shadow: 0 10px 40px rgba(15,23,42,0.08);
    }

    .confirmation-icon {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: #dcfce7;
        color: #16a34a;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 36px;
        margin: 0 auto 20px;
    }

    .confirmation-card h1 {
        font-size: 28px;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 8px;
    }

    .confirmation-card .sub {
        font-size: 16px;
        color: #6b7280;
        margin-bottom: 24px;
    }

    .confirmation-details {
        text-align: left;
        background: #f8fafc;
        border-radius: 12px;
        padding: 20px 24px;
        margin-bottom: 24px;
    }

        .confirmation-details .row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid #e5e7eb;
            font-size: 14px;
        }

            .confirmation-details .row:last-child {
                border-bottom: none;
            }

        .confirmation-details .label {
            color: #6b7280;
        }

        .confirmation-details .value {
            font-weight: 600;
            color: #0f172a;
        }

    .btn-dashboard {
        display: inline-block;
        padding: 14px 32px;
        background: #2563eb;
        color: white;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        font-size: 15px;
        margin: 8px;
    }

        .btn-dashboard:hover {
            background: #1d4ed8;
            color: white;
        }

    .btn-home {
        display: inline-block;
        padding: 14px 32px;
        border: 1.5px solid #e5e7eb;
        border-radius: 10px;
        text-decoration: none;
        color: #4b5563;
        font-weight: 600;
        font-size: 15px;
        margin: 8px;
    }

        .btn-home:hover {
            background: #f9fafb;
        }

    @@media (max-width: 600px) {
        .confirmation-card {
            padding: 32px 20px;
        }
    }
</style>

@if (Model != null)
{
    <div class="confirmation-wrapper">
        <div class="confirmation-card">
            <div class="confirmation-icon">
                <i class="fa-regular fa-circle-check"></i>
            </div>
            <h1>Booking Confirmed! 🎉</h1>
            <p class="sub">Your reservation has been successfully confirmed.</p>

            <div class="confirmation-details">
                <div class="row">
                    <span class="label">Reservation Number</span>
                    <span class="value">@Model.ReservationNumber</span>
                </div>
                <div class="row">
                    <span class="label">Property</span>
                    <span class="value">@Model.PropertyName</span>
                </div>
                <div class="row">
                    <span class="label">Check-In</span>
                    <span class="value">@Model.CheckInDate.ToString("dddd, MMMM dd, yyyy")</span>
                </div>
                <div class="row">
                    <span class="label">Check-Out</span>
                    <span class="value">@Model.CheckOutDate.ToString("dddd, MMMM dd, yyyy")</span>
                </div>
                <div class="row">
                    <span class="label">Guests</span>
                    <span class="value">@Model.NumberOfGuests guests</span>
                </div>
                <div class="row">
                    <span class="label">Total Price</span>
                    <span class="value">@Model.Currency @Model.TotalPrice.ToString("N0")</span>
                </div>
                @if (!string.IsNullOrEmpty(Model.RoomTypeName))
                {
                    <div class="row">
                        <span class="label">Room Type</span>
                        <span class="value">@Model.RoomTypeName</span>
                    </div>
                }
            </div>

            <p style="font-size: 14px; color: #6b7280; margin-bottom: 20px;">
                A confirmation email has been sent to your registered email address.
            </p>

            <div>
                <a href="@Url.Action("MyReservations", "Reservation")" class="btn-dashboard">
                    <i class="fa-regular fa-calendar"></i> View My Reservations
                </a>
                <a href="@Url.Action("Index", "Home")" class="btn-home">
                    <i class="fa-regular fa-house"></i> Home
                </a>
            </div>
        </div>
    </div>
}
else
{
    <div class="confirmation-wrapper">
        <div class="confirmation-card">
            <h1>Reservation Not Found</h1>
            <p>The reservation you're looking for doesn't exist.</p>
            <a href="@Url.Action("Index", "Home")" class="btn-dashboard">Go Home</a>
        </div>
    </div>
}